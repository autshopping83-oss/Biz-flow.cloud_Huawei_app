# Porta do servidor
PORT=3002

# OAuth2 Google — Obter em https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=https://biz-flow.cloud/api/auth/callback/google

# URL da plataforma (para redirecionamento apos callback)
APP_URL=https://biz-flow.cloud

# Base de dados PostgreSQL (para guardar refresh_tokens dos utilizadores)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizflow
DB_USER=postgres
DB_PASS=postgres
