# ============================================
# 📌 SUPABASE (Banco de Dados + Autenticação)
# ============================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-super-longa-aqui

# ============================================
# 🤖 GOOGLE GEMINI API (IA para otimização)
# ============================================
GEMINI_API_KEY=sua-chave-gemini-aqui

# ============================================
# 💳 PAYMENT SERVICE (Carteira de Pagamentos)
# ============================================
VITE_WALLET_ID=seu-wallet-id-aqui

# ============================================
# 📌 DESENVOLVIMENTO LOCAL
# ============================================
# Deixe como está se estiver rodando localmente
# Para produção na Vercel, deixe em branco ou remova
VITE_API_URL=http://localhost:5173
